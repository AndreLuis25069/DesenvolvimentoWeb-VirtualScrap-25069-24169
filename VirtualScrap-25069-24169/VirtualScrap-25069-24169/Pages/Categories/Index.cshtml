@page
@model VirtualScrap_25069_24169.Pages.Categories.IndexModel

@{
    ViewData["Title"] = "Categorias";
}

<div class="container my-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 text-dark fw-bold mb-1">📁 Gestão de Categorias</h1>
            <p class="text-muted small mb-0">Administra as categorias de materiais disponíveis no sistema.</p>
        </div>
        <a asp-page="Create" class="btn btn-dark btn-sm rounded-pill px-3">
            ➕ Criar Nova Categoria
        </a>
    </div>

    <div class="card shadow-sm border-light rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                <thead class="table-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">@Html.DisplayNameFor(model => model.Category[0].Name)</th>
                        <th class="text-end pe-4 py-3">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Category != null && Model.Category.Any())
                    {
                        foreach (var item in Model.Category)
                        {
                            <tr>
                                <td class="fw-bold text-dark ps-4 py-3">
                                    <span class="me-2">📦</span> @Html.DisplayFor(modelItem => item.Name)
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="d-inline-flex gap-2 align-items-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn text-secondary p-1" title="Editar">✏️</a>
                                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn text-danger p-1" title="Eliminar">🗑️</a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted small">
                                💡 Nenhuma categoria registada no sistema.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>