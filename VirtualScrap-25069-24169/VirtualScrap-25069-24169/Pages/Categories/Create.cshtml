@page
@model VirtualScrap_25069_24169.Pages.Categories.CreateModel

@{
    ViewData["Title"] = "Criar Categoria";
}

<div class="container my-4" style="max-width: 600px;">

    <div class="mb-4">
        <a asp-page="Index" class="btn btn-sm btn-outline-secondary">
            ← Voltar à Lista
        </a>
    </div>

    <div class="card border-light shadow-sm rounded-3">
        <div class="card-body p-4">

            <div class="mb-4">
                <span class="badge bg-dark text-uppercase mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                    Configurações
                </span>
                <h1 class="h3 text-dark fw-bold mb-0">Nova Categoria</h1>
                <p class="text-muted small mb-0">Adiciona uma nova tipologia de material ao sistema.</p>
            </div>

            <hr class="text-muted opacity-25 mb-4" />

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <div class="form-group">
                            <label asp-for="Category.Name" class="form-label text-secondary fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                NOME DA CATEGORIA <span class="text-danger">*</span>
                            </label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-0 text-muted">📁</span>
                                <input asp-for="Category.Name" class="form-control bg-white border-0 py-2" style="font-size: 0.9rem;" placeholder="Ex: Metais Não Ferrosos, Componentes..." required />
                            </div>
                            <span asp-validation-for="Category.Name" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>

                <hr class="text-muted opacity-25 my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-page="Index" class="btn btn-sm btn-light px-3 fw-medium rounded-pill">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-sm btn-dark px-4 fw-medium rounded-pill shadow-sm">
                        ➕ Criar Categoria
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}