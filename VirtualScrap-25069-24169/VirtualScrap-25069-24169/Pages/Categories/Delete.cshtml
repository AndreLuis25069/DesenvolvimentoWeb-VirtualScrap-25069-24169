@page
@model VirtualScrap_25069_24169.Pages.Categories.DeleteModel

@{
    ViewData["Title"] = "Eliminar Categoria";
}

<div class="container my-4" style="max-width: 600px;">

    <div class="mb-4">
        <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">
            ← Voltar à Lista
        </a>
    </div>

    <div class="card border-light shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">

            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="bg-light text-dark rounded-circle d-flex align-items-center justify-content-center shadow-sm fs-4" style="width: 50px; height: 50px;">
                    📁
                </div>
                <div>
                    <span class="badge bg-secondary text-uppercase mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                        Configurações / Remoção
                    </span>
                    <h1 class="h3 text-dark fw-bold mb-0">@Model.Category.Name</h1>
                </div>
            </div>

            <hr class="text-muted opacity-25 mb-4" />

            <div class="row g-3 mb-4">
                <div class="col-12">
                    <small class="text-muted d-block fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">NOME DA CATEGORIA</small>
                    <span class="text-dark fw-medium fs-5">@Html.DisplayFor(model => model.Category.Name)</span>
                </div>
            </div>

            <hr class="text-muted opacity-25 mb-4" />

            <div class="d-flex justify-content-end gap-2">
                <a asp-page="./Index" class="btn btn-sm btn-light px-3 fw-medium rounded-pill">
                    Cancelar
                </a>
                <button type="button" class="btn btn-sm btn-danger px-4 fw-medium rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                    🗑️ Eliminar Categoria
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Modal de Confirmação -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
        <div class="modal-content border-0 shadow rounded-3">

            <div class="modal-header border-0 pt-4 px-4 d-flex align-items-center">
                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm fs-5 me-3" style="width: 42px; height: 42px; flex-shrink: 0;">
                    ⚠️
                </div>
                <div>
                    <span class="badge bg-danger text-uppercase mb-1" style="font-size: 0.6rem; letter-spacing: 0.5px;">Ação Crítica</span>
                    <h5 class="modal-title text-dark fw-bold" id="modalLabel">Confirmar Eliminação</h5>
                </div>
                <button type="button" class="btn-close ms-auto mb-3" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body px-4 pb-0">
                <p class="text-secondary small mb-3">
                    Tens a certeza que queres eliminar permanentemente a categoria <strong>@Model.Category.Name</strong>? Esta ação não pode ser desfeita.
                </p>

                @*
                   Nota: Se o teu modelo Category tiver uma lista de anúncios/sucata associada (ex: Category.Posts),
                   podes descomentar este bloco abaixo para listar os itens afetados, tal como fizeste nos Users.
                *@
                @*
                @if (Model.Category.Posts != null && Model.Category.Posts.Any())
                {
                    <div class="alert alert-warning border-0 rounded-3 p-3 mb-0 shadow-sm">
                        <small class="fw-bold d-block text-warning-emphasis mb-2" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                            AVISO: OS SEGUINTES ITENS ESTÃO VINCULADOS A ESTA CATEGORIA:
                        </small>
                        <ul class="mb-0 ps-3 text-dark" style="font-size: 0.85rem; max-height: 120px; overflow-y: auto;">
                            @foreach (var item in Model.Category.Posts)
                            {
                                <li class="py-1">📦 @item.Title</li>
                            }
                        </ul>
                    </div>
                }
                *@
            </div>

            <div class="modal-footer border-0 p-4 d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-sm btn-light px-3 fw-medium rounded-pill" data-bs-dismiss="modal">
                    Não, Cancelar
                </button>

                <form method="post" class="d-inline">
                    <input type="hidden" asp-for="Category.Id" />
                    <button type="submit" class="btn btn-sm btn-danger px-4 fw-medium rounded-pill shadow-sm">
                        🔥 Sim, Eliminar
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>