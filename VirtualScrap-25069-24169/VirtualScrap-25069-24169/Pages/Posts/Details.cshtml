@page
@using Microsoft.AspNetCore.Identity
@model VirtualScrap_25069_24169.Pages.Posts.DetailsModel
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Detalhes do Post";
}

<div class="container my-4">
    <div class="mb-3">
        <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">
            ← Voltar à Lista
        </a>
    </div>

    @{
        var donoPost = User.Identity.IsAuthenticated &&
                       Model.Post.PostOwner != null &&
                       Model.Post.PostOwner.IdUser == UserManager.GetUserId(User);
    }

    <div class="row g-4">
        <div class="col-12 col-md-6">
            <div class="card border-light shadow-sm overflow-hidden sticky-md-top" style="top: 20px; z-index: 1;">
                <div class="ratio ratio-4x3 bg-light">
                    @if (!string.IsNullOrEmpty(Model.Post.Photo) && Model.Post.Photo != "noImage.jpg")
                    {
                        <img src="~/images/@Model.Post.Photo" class="img-fluid object-fit-cover" alt="@Model.Post.Title" asp-append-version="true" />
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center text-muted bg-secondary-subtle">
                            <span class="fs-4">📷</span>
                            <span class="small mt-1">Sem foto disponível</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex flex-column justify-content-between">
            <div>
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div>
                        @if (Model.Post.CategoryFK != null)
                        {
                            <span class="badge bg-light text-secondary border text-uppercase" style="font-size: 0.6rem;">
                                @Model.Post.PostCategory.Name
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle text-uppercase" style="font-size: 0.6rem;" title="A categoria original foi eliminada.">
                                ⚠️ Categoria Removida
                            </span>
                        }
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        @if (donoPost || User.IsInRole("Admin"))
                        {
                            <a asp-page="./Edit" asp-route-id="@Model.Post.Id" class="btn btn-xs btn-outline-dark py-1 px-2.5 d-flex align-items-center gap-1" style="font-size: 0.7rem; border-radius: 6px;">
                                ✏️ <span class="d-none d-sm-inline">Editar</span>
                            </a>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" asp-page-handler="Like" asp-route-id="@Model.Post.Id" class="d-flex align-items-center gap-1">
                                <span class="small text-muted fw-bold">@Model.totalLikes</span>
                                <button type="submit" class="btn p-0 border-0 bg-transparent text-danger shadow-none" style="outline: none;">
                                    @if (Model.JaTemLike)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-heart-fill" viewBox="0 0 16 16">
                                            <path fill-rule="evenodd" d="M8 1.314C12.438-3.248 23.534 4.735 8 15-7.534 4.736 3.562-3.248 8 1.314" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-heart text-secondary" viewBox="0 0 16 16">
                                            <path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143q.09.083.176.171a3 3 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15" />
                                        </svg>
                                    }
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="text-secondary" title="Faz login para guardar nos favoritos">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-heart" viewBox="0 0 16 16">
                                    <path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01z" />
                                </svg>
                            </a>
                        }
                    </div>
                </div>

                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                    <h1 class="h3 text-dark fw-bold m-0 flex-grow-1">@Model.Post.Title</h1>
                    <div class="bg-dark text-white mt-4 px-3 py-1.5 rounded-pill shadow-sm fw-bold fs-5">
                        € @Model.Post.Price.ToString("F2") /KG
                    </div>
                </div>

                <p class="text-muted small mb-1">
                    📍 @Model.Post.Localizacao , Portugal
                </p>
                <p class="text-muted small mb-3">
                    📅 Publicado em @Model.Post.PostDate.ToString("dd/MM/yyyy") por 
                    @if (Model.Post.PostOwner != null)
                    {
                        <a asp-page="/MyUsers/Details" asp-route-id="@Model.Post.PostOwner.Id" class="text-decoration-none fw-bold text-dark hover-warning transition ms-1">
                            👨‍🦱 @(string.IsNullOrEmpty(Model.Post.PostOwner.Name) ? "Anunciante" : Model.Post.PostOwner.Name)
                        </a>
                    }
                    else
                    {
                        <span class="text-muted fst-italic ms-1">Utilizador Removido</span>
                    }
                </p>

                <div class="mb-3">
                    <h6 class="fw-bold text-dark mb-1" style="font-size: 0.9rem;">Descrição</h6>
                    <p class="text-secondary mb-0" style="font-size: 0.9rem; white-space: pre-line;">
                        @Model.Post.Description
                    </p>
                </div>

                <hr class="text-muted opacity-25 my-3" />

                <div class="bg-light p-2.5 rounded-3 shadow-sm mb-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-muted d-block uppercase fw-bold" style="font-size: 0.6rem; letter-spacing: 0.5px;">CONTACTO DO VENDEDOR</small>
                        <span class="fs-5 fw-bold text-dark" style="font-size: 1.1rem !important;">
                            @(string.IsNullOrEmpty(Model.Post.CellPhone) ? "Não disponível" : Model.Post.CellPhone)
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Post.CellPhone))
                    {
                        <a href="tel:@Model.Post.CellPhone" class="btn btn-dark btn-sm rounded-pill px-3" style="font-size: 0.8rem; py: 1;">
                            Ligar
                        </a>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-light rounded-3">
                <div class="card-body p-3 d-flex flex-column" style="max-height: 260px; overflow: hidden;">
                    <h6 class="mb-2 text-dark fw-bold" style="font-size: 0.85rem;">
                        💬 Comentários
                    </h6>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form method="post" asp-page="./Details" asp-route-id="@Model.Post.Id" class="d-flex gap-2 align-items-start mb-2 flex-shrink-0">
                            <div class="rounded-circle overflow-hidden bg-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm"
                                 style="width: 32px; height: 32px;">
                                @if (Model.MyUserLogado != null && !string.IsNullOrEmpty(Model.MyUserLogado.Photo) && Model.MyUserLogado.Photo != "noImage.jpg")
                                {
                                    <img src="~/images1/@Model.MyUserLogado.Photo" class="w-100 h-100 object-fit-cover" alt="Perfil" asp-append-version="true" />
                                }
                                else
                                {
                                    <img src="~/defaultProfileImage/No-profile-photo.jpg" class="w-100 h-100 object-fit-cover" alt="Perfil Padrão" asp-append-version="true" />
                                }
                            </div>

                            <div class="w-100 position-relative">
                                <textarea asp-for="NovoComentarioTexto"
                                          class="form-control bg-light border-0 py-2"
                                          rows="1"
                                          placeholder="Escreve um comentário..."
                                          style="font-size: 0.82rem; resize: none; border-radius: 18px; padding-left: 12px; padding-right: 40px; min-height: 34px; max-height: 50px;"
                                          oninput="this.style.height = '';this.style.height = Math.min(this.scrollHeight, 50) + 'px'"></textarea>
                                <span asp-validation-for="NovoComentarioTexto" class="text-danger small d-block" style="font-size: 0.7rem;"></span>
                                <button type="submit" class="btn btn-dark rounded-circle position-absolute d-flex align-items-center justify-content-center shadow-sm"
                                        style="right: 5px; top: 17px; transform: translateY(-50%); width: 26px; height: 26px; padding: 0;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" class="bi bi-send-fill text-white" viewBox="0 0 16 16">
                                        <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.001.26.41a.5.5 0 0 0 .886-.083zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471z" />
                                    </svg>
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-secondary py-1.5 text-center small mb-2 rounded-pill flex-shrink-0" style="font-size: 0.8rem;">
                            Para comentar, <a asp-area="Identity" asp-page="/Account/Login" class="fw-bold text-dark">faz login aqui</a>.
                        </div>
                    }

                    <div class="comments-list d-flex flex-column gap-2 pe-1 flex-grow-1" style="max-height: 150px; overflow-y: auto;">
                        @if (Model.Post.Commentaries != null && Model.Post.Commentaries.Any())
                        {
                            @foreach (var comentario in Model.Post.Commentaries)
                            {
                                <div class="d-flex gap-2 align-items-start">
                                    <div class="rounded-circle overflow-hidden bg-dark text-white d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm"
                                         style="width: 28px; height: 28px;">
                                        @if (comentario.Autor != null && !string.IsNullOrEmpty(comentario.Autor.Photo) && comentario.Autor.Photo != "noImage.jpg")
                                        {
                                            <img src="~/images1/@comentario.Autor.Photo" class="w-100 h-100 object-fit-cover" alt="Autor" asp-append-version="true" />
                                        }
                                        else
                                        {
                                            <img src="~/defaultProfileImage/No-profile-photo.jpg" class="w-100 h-100 object-fit-cover" alt="Perfil Padrão" asp-append-version="true" />
                                        }
                                    </div>

                                    <div class="bg-light p-2 rounded-3 w-100" style="border-top-left-radius: 0px !important;">
                                        <div class="d-flex justify-content-between align-items-center mb-0.5">
                                            <span class="fw-bold text-dark" style="font-size: 0.78rem;">
                                                @if (comentario.AutorFK == null || comentario.Autor == null)
                                                {
                                                    <span class="text-muted fst-italic">Utilizador Removido</span>
                                                }
                                                else
                                                {
                                                    <a asp-page="/MyUsers/Details" asp-route-id="@comentario.Autor.Id" class="text-decoration-none text-dark fw-bold">
                                                        @comentario.Autor.Name
                                                    </a>
                                                }
                                            </span>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted" style="font-size: 0.6rem;">
                                                    🕒 @comentario.CommentDate.ToString("dd/MM/yyyy HH:mm")
                                                </span>

                                                @if (comentario.AutorFK != null && (Model.MyUserIdLogado == comentario.AutorFK || User.IsInRole("Admin") || Model.MyUserIdLogado == Model.Post.OwnerFK))
                                                {
                                                    <div class="d-flex gap-1">
                                                        <button type="button" onclick="ativarEdicao(@comentario.Id)" class="text-primary p-0 border-0 bg-transparent" style="font-size: 0.7rem;" title="Editar">
                                                            ✏️
                                                        </button>
                                                        <form method="post" asp-page-handler="DeleteComentario" asp-route-id="@Model.Post.Id" asp-route-comentarioId="@comentario.Id" onsubmit="return confirm('Tens a certeza que queres eliminar este comentário?');">
                                                            <button type="submit" class="text-danger p-0 border-0 bg-transparent" style="font-size: 0.7rem;" title="Eliminar">
                                                                ❌
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <p id="texto-@comentario.Id" class="text-secondary m-0" style="font-size: 0.78rem; white-space: pre-line;">
                                            @comentario.Description
                                        </p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-2 text-muted">
                                <span class="d-block" style="font-size: 0.75rem;">💡 Sê o primeiro a comentar!</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function activarEdicao(id) {
        document.getElementById('texto-' + id).classList.add('d-none');
        document.getElementById('form-edit-' + id).classList.remove('d-none');
    }
    function cancelarEdicao(id) {
        document.getElementById('texto-' + id).classList.remove('d-none');
        document.getElementById('form-edit-' + id).classList.add('d-none');
    }
</script>

<style>
    .comments-list::-webkit-scrollbar { width: 5px; }
    .comments-list::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
    .comments-list::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }
    .hover-warning:hover { color: #ffc107 !important; }
    .transition { transition: color 0.15s ease-in-out; }
    .btn-xs { padding: 0.2rem 0.4rem; font-size: 0.75rem; }
</style>