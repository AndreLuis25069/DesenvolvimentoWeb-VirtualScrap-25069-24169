@page
@model VirtualScrap_25069_24169.Pages.Posts.IndexModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>

    
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
    @foreach (var item in Model.Post)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-light">
                        
                <div class="ratio ratio-4x3 bg-light rounded-top overflow-hidden">
                    @if (!string.IsNullOrEmpty(item.Photo))
                    {
                        <img src="~/images/@item.Photo" class="card-img-top object-fit-cover" alt="@item.Title" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center text-muted bg-secondary-subtle">
                            <span>Sem foto</span>
                        </div>
                    }
                </div>

                <div class="card-body d-flex flex-column p-2">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fs-6 fw-bold text-dark">
                            @string.Format(new System.Globalization.CultureInfo("pt-PT"), "{0:C}", item.Price)
                        </span>
                        <span class="badge bg-light text-secondary border text-uppercase" style="font-size: 0.6rem;">
                            @item.PostCategory.Name
                        </span>
                    </div>

                    <h6 class="card-title text-truncate text-dark mb-1" style="font-size: 0.85rem;" title="@item.Title">
                        @item.Title
                    </h6>

                    <p class="card-text text-muted small text-truncate mb-2 flex-grow-1" style="font-size: 0.75rem;">
                        @item.Description
                    </p>

                    <div class="mt-auto pt-2 border-top text-secondary" style="font-size: 0.75rem;">
                        <div class="row g-0 mb-1">
                            <div class="col-6 text-start">
                                <span>📅 @item.PostDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="col-6 text-end">
                                @if (!string.IsNullOrEmpty(item.CellPhone))
                                {
                                    <span class="text-truncate d-inline-block" style="max-width: 90px;" title="@item.CellPhone">
                                        📞 @item.CellPhone
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="row g-0">
                            <div class="col-12 text-start text-truncate">
                                <span>📍 @(string.IsNullOrEmpty(item.Localizacao)   ? "Portugal" : item.Localizacao+", Portugal")</span>
                            </div>
                        </div>
                        <div class="row g-0">
                            <div class="col-12 text-start text-truncate">
                                <span> 👨‍🦱 @(string.IsNullOrEmpty(item.PostOwner.Name) ? "Owner" : item.PostOwner.Name)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-transparent border-0 pt-0 pb-2 px-2 d-flex gap-1">
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-dark flex-grow-1" style="font-size: 0.75rem;">Ver</a> 
                    @{
                        // Verifica se o utilizador está autenticado e se o GUID dele coincide com o GUID do criador do post
                        var donoPost = User.Identity.IsAuthenticated &&
                        item.PostOwner != null &&
                        item.PostOwner.IdUser == UserManager.GetUserId(User);
                    }

                    @if (donoPost)
                    {
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="font-size: 0.75rem;">✏️</a>
                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" style="font-size: 0.75rem;">🗑️</a>
                    }
                </div>

            </div>
        </div>
    }
</div>

   

