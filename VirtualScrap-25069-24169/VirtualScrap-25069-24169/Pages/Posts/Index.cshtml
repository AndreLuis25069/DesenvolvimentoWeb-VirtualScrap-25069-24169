@page
@model VirtualScrap_25069_24169.Pages.Posts.IndexModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Index";
}

<div class="container my-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="h3 text-dark fw-bold mb-0">Index</h1>
            <p class="text-muted small mb-0">
                <a asp-page="Create" class="btn btn-sm btn-dark mt-2 rounded-pill px-3">Create New</a>
            </p>
        </div>

        <div style="max-width: 350px;" class="w-100">
            <div class="input-group">
                <span class="input-group-text bg-light border-secondary-subtle">🔍</span>
                <input type="text" id="barraPesquisa" class="form-control border-secondary-subtle" placeholder="Procurar por título..." style="font-size: 0.9rem;" />
            </div>
        </div>
    </div>

    <div id="mensagemSemResultados" class="alert alert-light text-center border py-4 d-none">
        <span class="d-block text-muted mb-2">💡 Não foram encontrados posts com esse título.</span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3" id="listaPosts">
        @foreach (var item in Model.Post)
        {
            <div class="col post-card" data-title="@item.Title.ToLower()">
                <div class="card h-100 shadow-sm border-light">

                    <div class="ratio ratio-4x3 bg-light rounded-top overflow-hidden">
                        @if (!string.IsNullOrEmpty(item.Photo))
                        {
                            <img src="~/images/@item.Photo" class="card-img-top object-fit-cover" alt="@item.Title" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center text-muted bg-secondary-subtle">
                                <span>Sem foto</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column p-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fs-6 fw-bold text-dark">
                                @string.Format(new System.Globalization.CultureInfo("pt-PT"), "{0:C}", item.Price)
                            </span>
                            <span class="badge bg-light text-secondary border text-uppercase" style="font-size: 0.6rem;">
                                @item.PostCategory.Name
                            </span>
                        </div>

                        <h6 class="card-title text-truncate text-dark mb-1" style="font-size: 0.85rem;" title="@item.Title">
                            @item.Title
                        </h6>

                        <p class="card-text text-muted small text-truncate mb-2 flex-grow-1" style="font-size: 0.75rem;">
                            @item.Description
                        </p>

                        <div class="mt-auto pt-2 border-top text-secondary" style="font-size: 0.75rem;">
                            <div class="row g-0 mb-1">
                                <div class="col-6 text-start">
                                    <span>📅 @item.PostDate.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="col-6 text-end">
                                    @if (!string.IsNullOrEmpty(item.CellPhone))
                                    {
                                        <span class="text-truncate d-inline-block" style="max-width: 90px;" title="@item.CellPhone">
                                            📞 @item.CellPhone
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="row g-0">
                                <div class="col-12 text-start text-truncate">
                                    <span>📍 @(string.IsNullOrEmpty(item.Localizacao) ? "Portugal" : item.Localizacao + ", Portugal")</span>
                                </div>
                            </div>
                            <div class="row g-0">
                                <div class="col-12 text-start text-truncate">
                                    <span> 👨‍🦱 @(string.IsNullOrEmpty(item.PostOwner.Name) ? "Owner" : item.PostOwner.Name)</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pt-0 pb-2 px-2 d-flex gap-1">
                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-dark flex-grow-1" style="font-size: 0.75rem;">Ver</a>
                        @{
                            var donoPost = User.Identity.IsAuthenticated &&
                            item.PostOwner != null &&
                            item.PostOwner.IdUser == UserManager.GetUserId(User);
                        }

                        @if (donoPost || User.IsInRole("Admin"))
                        {
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="font-size: 0.75rem;">✏️</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" style="font-size: 0.75rem;">🗑️</a>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('barraPesquisa').addEventListener('input', function (e) {
        const termoPesquisa = e.target.value.toLowerCase().trim();
        const cartoes = document.querySelectorAll('.post-card');
        let encontrouAlgum = false;

        cartoes.forEach(function (cartao) {
            const titulo = cartao.getAttribute('data-title');

            // Se o título contiver o termo pesquisado, mostra o cartão, senão esconde
            if (titulo.includes(termoPesquisa)) {
                cartao.classList.remove('d-none');
                encontrouAlgum = true;
            } else {
                cartao.classList.add('d-none');
            }
        });

        // Mostra a mensagem de aviso se a pesquisa não bater com nenhum card
        const mensagem = document.getElementById('mensagemSemResultados');
        if (encontrouAlgum || termoPesquisa === "") {
            mensagem.classList.add('d-none');
        } else {
            mensagem.classList.remove('d-none');
        }
    });
</script>

   

