@using Microsoft.AspNetCore.Identity
@using VirtualScrap_25069_24169.Data.Model
@inject VirtualScrap_25069_24169.Data.ApplicationDbContext Context

@inject UserManager<IdentityUser> UserManager
@using System.Security.Claims
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VirtualScrap</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VirtualScrap_25069_24169.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark border-bottom shadow-sm py-3 mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-white" asp-area="" asp-page="/Index">
                    ♻️ Virtual<span class="text-warning">Scrap</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto mb-2 mb-md-0 gap-2">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded text-light hover-effect" asp-area="" asp-page="/Index">🏠 Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded text-light hover-effect" asp-area="" asp-page="/Posts/Index">📦 Posts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded text-light hover-effect" asp-area="" asp-page="/MyUsers/index">👥 Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded text-light hover-effect" asp-area="" asp-page="/Categories/Index">🏷️ Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded text-light hover-effect" asp-area="" asp-page="/Privacy">🔒 Privacy</a>
                        </li>
                    </ul>

                    @{
                        var loginGUID = User.FindFirstValue(ClaimTypes.NameIdentifier);

                        if (string.IsNullOrEmpty(loginGUID))
                        {
                            <div class="d-flex align-items-center gap-2 border-start ps-md-3 border-secondary">
                                <a class="btn btn-link text-light text-decoration-none px-3" asp-area="Identity" asp-page="/Account/Login">
                                    🔑 Entrar
                                </a>
                                <a class="btn btn-warning fw-bold text-dark px-3 shadow-sm" asp-area="Identity" asp-page="/Account/Register">
                                    📝 Registar
                                </a>
                            </div>
                        }
                        else
                        {
                            //Ir buscar os dados do utilizador com sessão iniciada á base de dados
                            var dadosDoPerfil = Context.MyUsers.FirstOrDefault(u => u.IdUser == loginGUID);
                            var fotoNome = dadosDoPerfil?.Photo;
                            var nome = dadosDoPerfil != null ? dadosDoPerfil.Name : (User.Identity?.Name ?? "Utilizador");
                            var idDoPerfil = dadosDoPerfil != null ? dadosDoPerfil.Id : 0;


                            string fotoDePerfil;

                            // Se o utilizador tem uma foto registada na Base de Dados
                            if (!string.IsNullOrEmpty(fotoNome) && fotoNome != "noImage.jpg")
                            {
                                //Vai a diretoria para as fotos de perfil do utilizador
                                fotoDePerfil = $"/images1/{fotoNome}";
                            }
                            else
                            {
                                //Aponta para a imagem defaul em caso do perfil não ter imagem
                                fotoDePerfil = "/defaultProfileImage/No-profile-photo.jpg";
                            }
                            
                            
                                
                            
                                    <a class="btn btn-link text-light text-decoration-none px-3 d-inline-flex align-items-center gap-2" asp-page="/MyUsers/Details" asp-route-id="@idDoPerfil">
                                <img src="@fotoDePerfil" alt="Avatar" style="width:30px; height:30px; border-radius:50%; object-fit:cover;" /> @nome
                            </a>

                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                                <button type="submit" class="nav-link btn btn-link text-light bg-danger p-1">Logout</button>
                            </form>

                        }

                    }

                            
                                                    
       

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-auto">
        <div class="container d-flex justify-content-between align-items-center flex-wrap">
            <span>&copy; 2026 - <span class="fw-bold text-dark">VirtualScrap</span> - Todos os direitos reservados.</span>
            <a class="text-decoration-none text-muted" asp-area="" asp-page="/Privacy">Política de Privacidade</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>