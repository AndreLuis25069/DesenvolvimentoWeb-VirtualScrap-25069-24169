@page
@using Microsoft.AspNetCore.Identity
@model VirtualScrap_25069_24169.Pages.MyUsers.IndexModel
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager

@{
    ViewData["Title"] = "Utilizadores";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 text-dark fw-bold mb-1">👤 Gestão de Utilizadores</h1>
            <p class="text-muted small mb-0">Administra as permissões e perfis de acesso do sistema.</p>
        </div>
        <a asp-page="Create" class="btn btn-dark btn-sm rounded-pill px-3">
            ➕ Criar Novo Perfil
        </a>
    </div>

    <div class="card shadow-sm border-light">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                <thead class="table-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.MyUser[0].Name)</th>
                        <th>@Html.DisplayNameFor(model => model.MyUser[0].CellPhone)</th>
                        <th>Estatuto / Cargo</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MyUser)
                    {
                        var isAdmin = await UserManager.IsInRoleAsync(new IdentityUser { Id = item.IdUser }, "Admin");

                        <tr>
                            <td class="fw-bold text-dark ps-4">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td class="text-secondary">
                                @(string.IsNullOrEmpty(item.CellPhone) ? "—" : item.CellPhone)
                            </td>
                            <td>
                                @if (isAdmin)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 rounded-pill uppercase fw-bold" style="font-size: 0.7rem;">
                                        ⚙️ Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary border px-2.5 py-1.5 rounded-pill uppercase fw-bold" style="font-size: 0.7rem;">
                                        👤 Utilizador
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-inline-flex gap-2 align-items-center">

                                    @if (item.IdUser != null)
                                    {
                                        @if (isAdmin)
                                        {
                                            <!-- Botão que abre o Modal de Despromover -->
                                            <button type="button" class="btn btn-sm btn-outline-danger py-1 px-2.5" style="font-size: 0.75rem; border-radius: 6px;" data-bs-toggle="modal" data-bs-target="#modalRetirarAdmin-@item.Id">
                                                Retirar Admin
                                            </button>
                                        }
                                        else
                                        {
                                            <!-- Botão que abre o Modal de Promover -->
                                            <button type="button" class="btn btn-sm btn-outline-success py-1 px-2.5" style="font-size: 0.75rem; border-radius: 6px;" data-bs-toggle="modal" data-bs-target="#modalTornarAdmin-@item.Id">
                                                Tornar Admin
                                            </button>
                                        }
                                    }

                                    <span class="text-muted opacity-25">|</span>

                                    <div class="btn-group btn-group-sm">
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn text-secondary p-1" title="Editar">✏️</a>
                                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn text-secondary p-1" title="Detalhes">👁️</a>
                                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn text-danger p-1" title="Eliminar">🗑️</a>
                                    </div>
                                </div>
                            </td>
                        </tr>

                        <!-- MODAL: Tornar Admin -->
                        <div class="modal fade" id="modalTornarAdmin-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
                                <div class="modal-content border-0 shadow rounded-3 text-start">
                                    <div class="modal-header border-0 pt-4 px-4 d-flex align-items-center">
                                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm fs-5 me-3" style="width: 42px; height: 42px; flex-shrink: 0;">
                                            🛡️
                                        </div>
                                        <div>
                                            <span class="badge bg-success text-uppercase mb-1" style="font-size: 0.6rem; letter-spacing: 0.5px;">Permissões</span>
                                            <h5 class="modal-title text-dark fw-bold">Promover Utilizador</h5>
                                        </div>
                                        <button type="button" class="btn-close ms-auto mb-3" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body px-4 pb-0">
                                        <p class="text-secondary small mb-0">
                                            Queres dar permissões totais de <strong>Administrador</strong> a <strong>@item.Name</strong>? Este perfil passará a poder gerir todas as áreas do VirtualScrap.
                                        </p>
                                    </div>
                                    <div class="modal-footer border-0 p-4 d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-sm btn-light px-3 fw-medium rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                                        <form method="post" asp-page-handler="TornarAdmin" asp-route-idUser="@item.IdUser" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success px-4 fw-medium rounded-pill shadow-sm">
                                                ✅ Sim, Tornar Admin
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- MODAL: Retirar Admin -->
                        <div class="modal fade" id="modalRetirarAdmin-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
                                <div class="modal-content border-0 shadow rounded-3 text-start">
                                    <div class="modal-header border-0 pt-4 px-4 d-flex align-items-center">
                                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm fs-5 me-3" style="width: 42px; height: 42px; flex-shrink: 0;">
                                            ⚠️
                                        </div>
                                        <div>
                                            <span class="badge bg-danger text-uppercase mb-1" style="font-size: 0.6rem; letter-spacing: 0.5px;">Alteração Crítica</span>
                                            <h5 class="modal-title text-dark fw-bold">Despromover Administrador</h5>
                                        </div>
                                        <button type="button" class="btn-close ms-auto mb-3" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body px-4 pb-0">
                                        <p class="text-secondary small mb-0">
                                            Tens a certeza que queres retirar os privilégios de Admin a <strong>@item.Name</strong>? O utilizador perderá o acesso às configurações globais.
                                        </p>
                                    </div>
                                    <div class="modal-footer border-0 p-4 d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-sm btn-light px-3 fw-medium rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                                        <form method="post" asp-page-handler="RetirarAdmin" asp-route-idUser="@item.IdUser" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger px-4 fw-medium rounded-pill shadow-sm">
                                                🔥 Sim, Retirar Permissões
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                </tbody>
            </table>
        </div>
    </div>
</div>