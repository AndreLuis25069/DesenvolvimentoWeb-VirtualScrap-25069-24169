@page
@model LogoutModel
@{
    ViewData["Title"] = "Terminar Sessão";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card border-light shadow-sm text-center p-4" style="max-width: 450px; width: 100%; border-radius: 15px;">
        <div class="card-body">

            @{
                if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="mb-4">
                        <span class="display-4 text-dark">👋</span>
                    </div>

                    <h1 class="h3 text-dark fw-bold mb-2">@ViewData["Title"]</h1>
                    <p class="text-secondary small mb-4">Desejas mesmo terminar a tua sessão no VirtualScrap?</p>

                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition mb-3">
                            Sim, terminar sessão
                        </button>
                    </form>

                    <a href="/" class="text-decoration-none text-muted small hover-dark transition d-block">
                        Não, continuar ligado
                    </a>
                }
                else
                {
                    <div class="mb-4">
                        <span class="display-3 text-dark">✅</span>
                    </div>

                    <h1 class="h3 text-dark fw-bold mb-2">Sessão Terminada</h1>
                    <p class="text-secondary fs-6 mb-4">A tua sessão foi encerrada com sucesso. Volte sempre!</p>

                    <hr class="text-muted opacity-25 mb-4" />

                    <a href="/" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition">
                        Voltar à Página Inicial →
                    </a>
                }
            }

        </div>
    </div>
</div>

<style>
    .transition {
        transition: all 0.2s ease-in-out;
    }

    .btn-dark:hover {
        background-color: #343a40 !important;
        transform: translateY(-1px);
    }

    .hover-dark:hover {
        color: #212529 !important;
        text-decoration: underline !important;
    }
</style>