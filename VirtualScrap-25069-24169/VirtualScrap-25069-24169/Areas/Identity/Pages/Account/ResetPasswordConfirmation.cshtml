@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Palavra-passe Redefinida";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card border-light shadow-sm text-center p-4" style="max-width: 450px; width: 100%; border-radius: 15px;">
        <div class="card-body">

            <div class="mb-4">
                <span class="display-3 text-dark">✅</span>
            </div>

            <h1 class="h3 text-dark fw-bold mb-3">@ViewData["Title"]</h1>
            <p class="text-secondary fs-6 mb-4">
                A tua palavra-passe foi atualizada com sucesso. Já podes voltar a entrar na tua conta!
            </p>

            <hr class="text-muted opacity-25 mb-4" />

            <a asp-page="/Account/Login" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition">
                Ir para o Login
            </a>

        </div>
    </div>
</div>

<style>
    .transition {
        transition: all 0.2s ease-in-out;
    }

    .btn-dark:hover {
        background-color: #343a40 !important;
        transform: translateY(-1px);
    }
</style>