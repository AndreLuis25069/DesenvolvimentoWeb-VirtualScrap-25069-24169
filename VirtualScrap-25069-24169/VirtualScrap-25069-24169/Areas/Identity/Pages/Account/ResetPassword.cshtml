@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Redefinir Palavra-passe";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card border-light shadow-sm p-4" style="max-width: 450px; width: 100%; border-radius: 15px;">
        <div class="card-body">

            <div class="text-center mb-3">
                <span class="display-4 text-dark">🔐</span>
            </div>

            <h1 class="h3 text-center text-dark fw-bold mb-1">@ViewData["Title"]</h1>
            <p class="text-center text-muted small mb-4">Cria uma nova palavra-passe forte para a tua conta.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <input asp-for="Input.Code" type="hidden" />

                <div class="form-group mb-3">
                    <label asp-for="Input.Email" class="form-label small fw-bold text-secondary mb-1">E-mail</label>
                    <input asp-for="Input.Email" value="@Model.Input?.Email" class="form-control bg-light border-0 py-2.5" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" style="border-radius: 10px; font-size: 0.9rem;" />
                    <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1" style="font-size: 0.75rem;"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Password" class="form-label small fw-bold text-secondary mb-1">Nova Palavra-passe</label>
                    <input asp-for="Input.Password" class="form-control bg-light border-0 py-2.5" autocomplete="new-password" aria-required="true" placeholder="••••••••" style="border-radius: 10px; font-size: 0.9rem;" />
                    <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1" style="font-size: 0.75rem;"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label small fw-bold text-secondary mb-1">Confirmar Nova Palavra-passe</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control bg-light border-0 py-2.5" autocomplete="new-password" aria-required="true" placeholder="••••••••" style="border-radius: 10px; font-size: 0.9rem;" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-1" style="font-size: 0.75rem;"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition mt-3">
                    Alterar Palavra-passe →
                </button>
            </form>

        </div>
    </div>
</div>

<style>
    .transition {
        transition: all 0.2s ease-in-out;
    }

    .btn-dark:hover {
        background-color: #343a40 !important;
        transform: translateY(-1px);
    }

    .form-control:focus {
        background-color: #f1f3f5 !important;
        box-shadow: none !important;
        border: none !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}