@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar Sessão";
}

<div class="container my-5" style="max-width: 500px;">

    
    <div class="text-center mb-4">
        <a class="navbar-brand fw-bold fs-2 text-dark text-decoration-none" asp-area="" asp-page="/Index" style="letter-spacing: -0.5px;">
            ♻️ Virtual<span class="text-warning">Scrap</span>
        </a>
        <p class="text-muted small mt-2 mb-0">Introduz as tuas credenciais para aceder ao mercado.</p>
    </div>

    <div class="card border-light shadow-sm rounded-3">
        <div class="card-body p-4 p-sm-5">

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="row g-3">
             
                    <div class="col-12">
                        <div class="form-group">
                            <label asp-for="Input.Email" class="form-label text-secondary fw-bold mb-1" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                ENDEREÇO DE EMAIL
                            </label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-0 text-muted">✉️</span>
                                <input asp-for="Input.Email" class="form-control bg-white border-0 py-2" style="font-size: 0.9rem;" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-group">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="Input.Password" class="form-label text-secondary fw-bold mb-0" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                    PALAVRA-PASSE
                                </label>
                                <a id="forgot-password" asp-page="./ForgotPassword" class="text-muted small text-decoration-none" style="font-size: 0.75rem;">
                                    Esqueceste-te?
                                </a>
                            </div>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-0 text-muted">🔒</span>
                                <input asp-for="Input.Password" class="form-control bg-white border-0 py-2" style="font-size: 0.9rem;" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>

               
                <div class="form-check my-3 text-start">
                    <input class="form-check-input check-custom shadow-sm" asp-for="Input.RememberMe" style="cursor: pointer;" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-secondary small" style="cursor: pointer; user-select: none;">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                
                <div class="mt-4 mb-2">
                    <button id="login-submit" type="submit" class="w-100 btn btn-dark py-2.5 fw-medium rounded-pill shadow-sm">
                        🔑 Entrar na Conta
                    </button>
                </div>

                
                <div class="text-center mt-4 border-top pt-3 opacity-75">
                    <p class="mb-1">
                        <small class="text-muted">Ainda não tens conta? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-dark fw-bold text-decoration-none border-bottom border-dark">Registar agora</a></small>
                    </p>
                    <p class="mb-0">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted small text-decoration-none" style="font-size: 0.8rem;">
                            🔄 Reenviar confirmação de email
                        </a>
                    </p>
                </div>
            </form>

         
            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center my-4 position-relative">
                    <hr class="text-muted opacity-25" />
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small" style="font-size: 0.75rem;">OU ENTRAR COM</span>
                </div>

                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="text-center">
                    <div class="d-flex justify-content-center gap-2">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-sm btn-outline-secondary px-3 rounded-pill" name="provider" value="@provider.Name" title="Entrar usando a tua conta @provider.DisplayName">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            }

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}