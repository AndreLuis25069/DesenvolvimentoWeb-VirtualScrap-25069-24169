@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmação de Registo";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card border-light shadow-sm text-center p-4" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body">
        
            <div class="mb-4">
                <span class="display-3 text-dark">✉️</span>
            </div>

            <h1 class="h3 text-dark fw-bold mb-3">@ViewData["Title"]</h1>

            @{
                if (Model.DisplayConfirmAccountLink)
                {
                    <div class="bg-secondary-subtle text-secondary small p-3 rounded-3 mb-4 text-start">
                        <span class="fw-bold d-block mb-1">💡 Nota de Desenvolvimento:</span>
                        Esta aplicação ainda não tem um servidor de e-mail real configurado. 
                        Consulta <a href="https://aka.ms/aspaccountconf" target="_blank" class="text-dark fw-medium text-decoration-underline">esta documentação</a> para saberes como o configurar.
                    </div>

                    <p class="text-secondary mb-4" style="font-size: 0.95rem;">
                        Em produção, este link seria enviado por e-mail. Para testares agora, clica no botão abaixo:
                    </p>

                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition">
                        Confirmar a Minha Conta →
                    </a>
                }
                else
                {
                    <p class="text-secondary fs-6 mb-0">
                        Obrigado por te registares! Por favor, **verifica a tua caixa de entrada** (e a pasta de spam) para confirmares a tua conta.
                    </p>
                }
            }
        </div>
    </div>
</div>

<style>
    
    .transition {
        transition: all 0.2s ease-in-out;
    }
    .btn-dark:hover {
        background-color: #343a40 !important;
        transform: translateY(-1px);
    }
</style>