@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "E-mail Confirmado";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card border-light shadow-sm text-center p-4" style="max-width: 450px; border-radius: 15px;">
        <div class="card-body">
            
            
            <div class="mb-4 d-flex justify-content-center">
                <div class="bg-success-subtle text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                </div>
            </div>

           
            <h1 class="h3 text-dark fw-bold mb-3">@ViewData["Title"]</h1>

           
            <div class="mb-4 fs-6 text-secondary">
                <partial name="_StatusMessage" model="Model.StatusMessage" />
            </div>

            <hr class="text-muted opacity-25 mb-4" />

            
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-dark w-100 rounded-pill py-2.5 fw-medium shadow-sm transition">
                Iniciar Sessão →
            </a>

        </div>
    </div>
</div>

<style>
    .transition {
        transition: all 0.2s ease-in-out;
    }

    .btn-dark:hover {
        background-color: #343a40 !important;
        transform: translateY(-1px);
    }

    .alert {
        border: none !important;
        background-color: transparent !important;
        color: #6c757d !important; 
        padding: 0 !important;
        margin: 0 !important;
    }

        
        .alert .btn-close,
        .alert button[class*="close"] {
            display: none !important;
        }
</style>